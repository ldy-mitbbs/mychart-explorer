# Copy to .env and fill in only the providers you want to use.
# The backend auto-loads this file from the repo root at startup.
# Existing shell env vars take precedence, so you can still override anything
# via `export FOO=...` before launching uvicorn.

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...

# Optional — override source export location / DB path.
# MYCHART_SOURCE=/path/to/epic/export
# MYCHART_DB=data/mychart.db
